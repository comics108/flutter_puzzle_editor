<UserControl x:Class="Comics.Editor.Controls.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<GroupBox Header="Settings" VerticalAlignment="Top">
		<Grid Margin="5" VerticalAlignment="Top" HorizontalAlignment="Left">
			<Label Content="Width" HorizontalAlignment="Left" VerticalAlignment="Top" />
			<TextBox Text="{Binding Width}" VerticalAlignment="Top" HorizontalAlignment="Left" Width="80" Margin="56,5,0,0" />
			<Label Content="Height" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="140,0,0,0"/>
			<TextBox Text="{Binding Height}" VerticalAlignment="Top" HorizontalAlignment="Left" Width="80" Margin="196,5,0,0" />
			<Button Content="Convert" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Margin="0,28,0,0" Command="{Binding ConvertCommand}"/>
		</Grid>
	</GroupBox>
</UserControl>
