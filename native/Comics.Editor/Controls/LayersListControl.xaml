<UserControl x:Class="Comics.Editor.Controls.LayersListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
	<GroupBox Header="Layers" VerticalAlignment="Top">
		<StackPanel Margin="5">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
				<Button Content="Add" Width="50" Command="{Binding AddLayerCommand}"/>
				<Button Content="Up" Width="50" Margin="5,0,0,0" Command="{Binding SelectedItem.MoveCommand, ElementName=listBox}" CommandParameter="{Binding Source={StaticResource upOffset}}"/>
				<Button Content="Down" Width="50" Margin="5,0,0,0" Command="{Binding SelectedItem.MoveCommand, ElementName=listBox}" CommandParameter="{Binding Source={StaticResource downOffset}}"/>
				<Button Content="Delete" Width="50" Margin="5,0,0,0" Command="{Binding SelectedItem.DeleteCommand, ElementName=listBox}"/>
			</StackPanel>
			<ListBox Name="listBox" Height="200" Margin="0,5,0,0" ItemsSource="{Binding Layers}" SelectedItem="{Binding SelectedItem}">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal">
							<CheckBox IsChecked="{Binding IsVisible}"/>
							<TextBlock Text="{Binding Image.File}" Margin="5,0,0,0"/>
						</StackPanel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</StackPanel>
	</GroupBox>
</UserControl>
