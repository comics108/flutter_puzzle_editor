<UserControl x:Class="Comics.Editor.Controls.SoundAnimControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400">
	<GroupBox Header="{Binding Type, Converter={StaticResource enumConverter}}" VerticalAlignment="Top" HorizontalAlignment="Left">
		<Grid Margin="5" VerticalAlignment="Top" HorizontalAlignment="Left">
			<local:AnimControl HorizontalAlignment="Left" VerticalAlignment="Top"/>
		</Grid>
	</GroupBox>
</UserControl>
