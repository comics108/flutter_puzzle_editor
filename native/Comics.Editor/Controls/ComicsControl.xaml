<UserControl x:Class="Comics.Editor.Controls.ComicsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" DataContextChanged="UserControl_DataContextChanged">
	<UserControl.Resources>
		<Style TargetType="{x:Type Thumb}">
			<Setter Property="Width">
				<Setter.Value>
					<MultiBinding Converter="{StaticResource thumbConverter}" ConverterParameter="{StaticResource thumbSize}">
						<Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Viewbox}}"/>
						<Binding Path="Child.ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Viewbox}}"/>
					</MultiBinding>
				</Setter.Value>
			</Setter>
			<Setter Property="Height" Value="{Binding Width, RelativeSource={RelativeSource Self}}" />
			<Setter Property="Background" Value="Black" />
		</Style>
	</UserControl.Resources>
	<Viewbox DockPanel.Dock="Left" Stretch="Uniform" StretchDirection="Both">
		<StackPanel Orientation="Horizontal">
			<ScrollViewer Name="scrollViewer" Background="#EEEEEE" MinWidth="400" Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource ratioConverter}, ConverterParameter={StaticResource ratio}}" ScrollChanged="ScrollViewer_ScrollChanged">
				<Grid Width="{Binding Width}" Height="{Binding Height}" Background="#000000">
					<local:LayersControl />
				</Grid>
			</ScrollViewer>
			<local:SoundsControl Orientation="Horizontal" />
		</StackPanel>
	</Viewbox>
</UserControl>
