<UserControl x:Class="Comics.Editor.Controls.SoundsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300" Name="soundsControl" Loaded="SoundsControl_Loaded">
	<ItemsControl ItemsSource="{Binding Sounds}">
		<ItemsControl.ItemsPanel>
			<ItemsPanelTemplate>
				<StackPanel Orientation="Horizontal" />
			</ItemsPanelTemplate>
		</ItemsControl.ItemsPanel>
		<ItemsControl.ItemTemplate>
			<DataTemplate>
				<Border BorderBrush="LightGray" BorderThickness="0,0,1,0" SnapsToDevicePixels="True">
					<ToggleButton Name="btn" Style="{StaticResource soundButton}" Click="Button_Click">
						<ToggleButton.Width>
							<MultiBinding Converter="{StaticResource thumbConverter}" ConverterParameter="{StaticResource soundSize}">
								<Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Viewbox}}"/>
								<Binding Path="Child.ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type Viewbox}}"/>
							</MultiBinding>
						</ToggleButton.Width>
						<local:SoundAnimsControl />
					</ToggleButton>
				</Border>
				<DataTemplate.Triggers>
					<DataTrigger Value="True">
						<DataTrigger.Binding>
							<MultiBinding Converter="{StaticResource equalsConverter}">
								<Binding Path="DataContext.SelectedItem" ElementName="soundsControl" />
								<Binding Path="." />
							</MultiBinding>
						</DataTrigger.Binding>
						<Setter TargetName="btn" Property="IsChecked" Value="True" />
					</DataTrigger>
				</DataTemplate.Triggers>
			</DataTemplate>
		</ItemsControl.ItemTemplate>
	</ItemsControl>
</UserControl>
