<UserControl x:Class="Comics.Editor.Controls.LayerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
			 xmlns:model="clr-namespace:Comics.Editor.Models"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="400" Name="layerControl">
	<StackPanel Orientation="{Binding Orientation, ElementName=layerControl}">
		<GroupBox Header="Layer" VerticalAlignment="Top" HorizontalAlignment="Left">
			<StackPanel Margin="5">
				<ItemsControl ItemsSource="{Binding Layer.Images}" AlternationCount="{Binding Layer.Images.Count}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid VerticalAlignment="Top" HorizontalAlignment="Left">
								<Label Content="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource enumConverter}}" ContentStringFormat="File ({0}):" HorizontalAlignment="Left" VerticalAlignment="Top"/>
								<TextBox Text="{Binding File, Mode=OneWay}" IsReadOnly="True" VerticalAlignment="Top" HorizontalAlignment="Left" Width="190" Margin="64,5,0,0" />
								<Button Content="..." HorizontalAlignment="Left" Margin="259,3,0,0" VerticalAlignment="Top" Width="25" Command="{Binding DataContext.ChangeCommand, ElementName=layerControl}" CommandParameter="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource enumConverter}}"/>
								<Label Content="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource enumConverter}}" ContentStringFormat="Popup ({0}):" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,25,0,0"/>
								<TextBox Text="{Binding Popup, Mode=OneWay}" IsReadOnly="True" VerticalAlignment="Top" HorizontalAlignment="Left" Width="190" Margin="64,30,0,0" />
								<Button Content="..." HorizontalAlignment="Left" Margin="259,28,0,0" VerticalAlignment="Top" Width="25" Command="{Binding DataContext.PopupCommand, ElementName=layerControl}" CommandParameter="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource enumConverter}}"/>
							</Grid>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				<CheckBox IsChecked="{Binding Layer.Preview}" Content="Preview" Margin="64,5,0,0" />
			</StackPanel>
		</GroupBox>
		<GroupBox Header="Animations" VerticalAlignment="Top" HorizontalAlignment="Left">
			<Grid Margin="5" VerticalAlignment="Top" HorizontalAlignment="Left">
				<ListBox ItemsSource="{Binding Layer.Animations}" SelectedItem="{Binding SelectedAnim}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="214" Height="150" />
				<Button Content="{Binding Source={x:Static model:AnimTypes.Translate}, Converter={StaticResource enumConverter}}" HorizontalAlignment="Left" Margin="219,0,0,0" VerticalAlignment="Top" Width="65" Command="{Binding AddAnimCommand}" CommandParameter="{Binding Source={x:Static model:AnimTypes.Translate}}"/>
				<Button Content="{Binding Source={x:Static model:AnimTypes.Rotate}, Converter={StaticResource enumConverter}}" HorizontalAlignment="Left" Margin="219,25,0,0" VerticalAlignment="Top" Width="65" Command="{Binding AddAnimCommand}" CommandParameter="{Binding Source={x:Static model:AnimTypes.Rotate}}"/>
				<Button Content="{Binding Source={x:Static model:AnimTypes.Scale}, Converter={StaticResource enumConverter}}" HorizontalAlignment="Left" Margin="219,50,0,0" VerticalAlignment="Top" Width="65" Command="{Binding AddAnimCommand}" CommandParameter="{Binding Source={x:Static model:AnimTypes.Scale}}"/>
				<Button Content="{Binding Source={x:Static model:AnimTypes.Alpha}, Converter={StaticResource enumConverter}}" HorizontalAlignment="Left" Margin="219,75,0,0" VerticalAlignment="Top" Width="65" Command="{Binding AddAnimCommand}" CommandParameter="{Binding Source={x:Static model:AnimTypes.Alpha}}"/>
				<Button Content="Delete" HorizontalAlignment="Left" Margin="219,100,0,0" VerticalAlignment="Top" Width="65" Command="{Binding DeleteAnimCommand}"/>
			</Grid>
		</GroupBox>
		<ContentControl Content="{Binding SelectedAnim}">
			<ContentControl.Resources>
				<DataTemplate DataType="{x:Type model:TranslateAnim}">
					<local:TranslateAnimControl />
				</DataTemplate>
				<DataTemplate DataType="{x:Type model:RotateAnim}">
					<local:RotateAnimControl />
				</DataTemplate>
				<DataTemplate DataType="{x:Type model:ScaleAnim}">
					<local:ScaleAnimControl />
				</DataTemplate>
				<DataTemplate DataType="{x:Type model:AlphaAnim}">
					<local:AlphaAnimControl />
				</DataTemplate>
			</ContentControl.Resources>
		</ContentControl>
	</StackPanel>
</UserControl>
