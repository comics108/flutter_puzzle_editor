<UserControl x:Class="Comics.Editor.Controls.PuzzleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Comics.Editor.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" DataContextChanged="UserControl_DataContextChanged">
	<UserControl.Resources>
		<Style TargetType="{x:Type Thumb}">
			<Setter Property="Width">
				<Setter.Value>
					<MultiBinding Converter="{StaticResource thumbConverter}" ConverterParameter="{StaticResource thumbSize}">
						<Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type ScrollViewer}}"/>
						<Binding Path="Content.ActualWidth" RelativeSource="{RelativeSource AncestorType={x:Type ScrollViewer}}"/>
					</MultiBinding>
				</Setter.Value>
			</Setter>
			<Setter Property="Height" Value="{Binding Width, RelativeSource={RelativeSource Self}}" />
			<Setter Property="Background" Value="Black" />
		</Style>
	</UserControl.Resources>
	<StackPanel>
		<StackPanel Orientation="Horizontal">
			<ScrollViewer Name="scrollViewer" Background="#EEEEEE" HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible" Height="400" Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource ratioConverter}, ConverterParameter={StaticResource ratio}}" ScrollChanged="ScrollViewer_ScrollChanged">
				<Grid Width="{Binding Width}" Height="{Binding Height}" Background="#000000">
					<local:LayersControl />
					<Grid.LayoutTransform>
						<ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}" />
					</Grid.LayoutTransform>
				</Grid>
			</ScrollViewer>
			<Slider Orientation="Vertical" Height="200" VerticalAlignment="Top" Margin="5,0,0,0" Minimum="0.125" Maximum="1" SmallChange="0.05" LargeChange="0.1" Value="{Binding Scale}" />
		</StackPanel>
		<local:SoundsControl Orientation="Vertical" HorizontalAlignment="Left" Height="{Binding ActualWidth, ElementName=scrollViewer}" />
	</StackPanel>
</UserControl>
