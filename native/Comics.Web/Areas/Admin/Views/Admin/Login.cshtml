@model LoginModel

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
	<title>Mahabharata - Login</title>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	@Styles.Render("~/bundles/css-admin")
</head>
<body class="hold-transition login-page">
	<div class="login-box">
		<div class="login-logo">
			@Html.ActionLink("Mahabharata", "Index")
		</div>
		<div class="login-box-body">
			<p class="login-box-msg">Authorize to start work</p>
			@using (Html.BeginForm())
			{
				<div class="form-group has-feedback">
					@Html.TextBoxFor(x => x.Login, new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Login) })
					<span class="glyphicon glyphicon-envelope form-control-feedback"></span>
					@Html.ValidationMessageFor(x => x.Login, null, new { @class = "help-block" })
				</div>
				<div class="form-group has-feedback">
					@Html.TextBoxFor(x => x.Password, new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Password), type = "password" })
					<span class="glyphicon glyphicon-lock form-control-feedback"></span>
					@Html.ValidationMessageFor(x => x.Password, null, new { @class = "help-block" })
				</div>
				<div class="form-group">
					@Html.ValidationSummary(true)
				</div>
				<div class="row">
					<div class="col-xs-8">
					</div>
					<div class="col-xs-4">
						<button type="submit" class="btn btn-primary btn-block btn-flat">Login</button>
					</div>
				</div>
			}
		</div>
	</div>
	@Scripts.Render("~/bundles/js-admin")
</body>
</html>
