@model string

@{
	var attrs = Html.ObjectToHtmlAttributes(ViewData["htmlAttributes"]);
}

@Html.HiddenFor(x => x)
@if (!string.IsNullOrEmpty(Model))
{
	<img class="image-small" src="@Model.Replace(ImageManager.SizePattern, (attrs["size"] ?? string.Empty).ToString())" />
}
<input type="file" name="@attrs["name"]" />
