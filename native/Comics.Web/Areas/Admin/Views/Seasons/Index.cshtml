@model ListModel<ListParams, Season>

@{
	ViewBag.Title = "Seasons";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="box">
	<table class="table table-striped table-bordered table-hover">
		<colgroup>
			<col>
			<col class="col-md-2">
			<col class="col-md-10">
		</colgroup>
		<thead>
			<tr>
				<th><a href="@Url.Action("Edit")" class="btn btn-xs btn-primary"><i class="fa fa-plus"></i></a></th>
				<th>Id</th>
				<th>Name</th>
			</tr>
		</thead>
		<tbody data-sortable="@Url.Action("Move")">
			@foreach (var item in Model.Items)
			{
				<tr data-id="@item.Id">
					<td class="text-nowrap">
						<a href="@Url.Action("Edit", new { item.Id })" class="btn btn-xs btn-primary"><i class="fa fa-pencil"></i></a>
						<a href="@Url.Action("Index", "Episodes", new { seasonId = item.Id })" class="btn btn-xs btn-primary"><i class="fa fa-file-video-o"></i></a>
					</td>
					<td>@Html.DisplayFor(x => item.Id)</td>
					<td>@Html.DisplayFor(x => item.Name)</td>
				</tr>
			}
		</tbody>
		<tfoot>
			<tr>
				<td colspan="3">
					@Html.Partial("Pager", Model.Items)
				</td>
			</tr>
		</tfoot>
	</table>
</div>

@section scripts {
	@Scripts.Render("~/bundles/js-sortable")
}