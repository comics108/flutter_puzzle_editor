@model ListModel<MusicParams, Music>

@{
	ViewBag.Title = "Music";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="box">
	<table class="table table-striped table-bordered table-hover">
		<colgroup>
			<col>
			<col class="col-md-2">
			<col class="col-md-4">
			<col class="col-md-6">
		</colgroup>
		<thead>
			<tr>
				<th><a href="@Url.Action("Edit")" class="btn btn-xs btn-primary"><i class="fa fa-plus"></i></a></th>
				<th>Id</th>
				<th>Name</th>
				<th>Author</th>
			</tr>
		</thead>
		<tbody data-sortable="@Url.Action("Move")">
			@foreach (var item in Model.Items)
			{
				<tr data-id="@item.Id">
					<td><a href="@Url.Action("Edit", new { item.Id })" class="btn btn-xs btn-primary"><i class="fa fa-pencil"></i></a></td>
					<td>@Html.DisplayFor(x => item.Id)</td>
					<td>@Html.DisplayFor(x => item.Name)</td>
					<td>@Html.DisplayFor(x => item.Author)</td>
				</tr>
			}
		</tbody>
		<tfoot>
			<tr>
				<td colspan="4">
					@Html.Partial("Pager", Model.Items)
				</td>
			</tr>
		</tfoot>
	</table>
</div>

@section scripts {
	@Scripts.Render("~/bundles/js-sortable")
}