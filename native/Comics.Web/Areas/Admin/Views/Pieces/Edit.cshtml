@model PieceModel

@{
	ViewBag.Title = "Puzzle piece";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "form-horizontal box", enctype = "multipart/form-data" }))
{
	<div class="box-header with-border">
		<h3 class="box-title">Puzzle piece information</h3>
	</div>
	<div class="box-body">
		@Html.ValidationSummary(true)
		<div class="form-group">
			@Html.LabelFor(x => x.Item.Id, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				<p class="form-control-static">@Html.DisplayFor(x => x.Item.Id)</p>
				@Html.HiddenFor(x => x.Item.Id)
				@Html.HiddenFor(x => x.Item.Order)
			</div>
		</div>
		<div class="form-group">
			@Html.LabelFor(x => x.Item.PuzzleId, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				<p class="form-control-static">@Html.DisplayFor(x => x.Item.Puzzle.Name)</p>
				@Html.HiddenFor(x => x.Item.PuzzleId)
			</div>
		</div>
		<div class="form-group">
			@Html.LabelFor(x => x.Item.X, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				@Html.EditorFor(x => x.Item.X, new { htmlAttributes = new { @class = "form-control" } })
				@Html.ValidationMessageFor(x => x.Item.X)
			</div>
		</div>
		<div class="form-group">
			@Html.LabelFor(x => x.Item.Y, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				@Html.EditorFor(x => x.Item.Y, new { htmlAttributes = new { @class = "form-control" } })
				@Html.ValidationMessageFor(x => x.Item.Y)
			</div>
		</div>
		<div class="form-group">
			@Html.LabelFor(x => x.Item.Width, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				@Html.EditorFor(x => x.Item.Width, new { htmlAttributes = new { @class = "form-control" } })
				@Html.ValidationMessageFor(x => x.Item.Width)
			</div>
		</div>
		<div class="form-group">
			@Html.LabelFor(x => x.Item.Height, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				@Html.EditorFor(x => x.Item.Height, new { htmlAttributes = new { @class = "form-control" } })
				@Html.ValidationMessageFor(x => x.Item.Height)
			</div>
		</div>
		@Html.FormGroupFor(x => x.Item.File, new { name = "archiveFile" })
		<div class="form-group">
			@Html.LabelFor(x => x.Item.Version, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				@Html.EditorFor(x => x.Item.Version, new { htmlAttributes = new { @class = "form-control" } })
				@Html.ValidationMessageFor(x => x.Item.Version)
			</div>
		</div>
		<div class="form-group">
			@Html.LabelFor(x => x.Item.Date, new { @class = "col-sm-2 control-label" })
			<div class="col-sm-10">
				@Html.EditorFor(x => x.Item.Date, new { htmlAttributes = new { @class = "form-control" } })
				@Html.ValidationMessageFor(x => x.Item.Date)
			</div>
		</div>
		<div class="form-group">
			<div class="col-sm-offset-2 col-sm-10">
				<button type="submit" class="btn btn-primary"><i class="fa fa-check"></i>&nbsp;&nbsp;Save</button>
				<a href="@Url.Action("Index")" class="btn btn-default"><i class="fa fa-close"></i>&nbsp;&nbsp;Cancel</a>
				@if (Model.Item.Id > 0)
				{
					<a href="@Url.Action("Delete", new { Model.Item.Id })" class="btn btn-danger" onclick="return confirm('Are you sure?');"><i class="fa fa-times"></i>&nbsp;&nbsp;Delete</a>
				}
			</div>
		</div>
	</div>
}
