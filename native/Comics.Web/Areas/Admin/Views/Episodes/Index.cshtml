@model ListModel<EpisodesParams, Episode>

@{
	ViewBag.Title = "Episodes";
	Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "form-horizontal box" }))
{
	<div class="box-header with-border">
		<h3 class="box-title">Filter</h3>
	</div>
	<div class="box-body">
		<div class="form-group">
			@Html.LabelFor(x => x.Param.SeasonId, new { @class = "col-sm-1 control-label" })
			<div class="col-sm-5">
				@Html.DropDownListFor(x => x.Param.SeasonId, Model.Param.Seasons.ToSelectList("Number"), new { @class = "form-control" })
				@Html.ValidationMessageFor(x => x.Param.SeasonId)
			</div>
		</div>
	</div>
	<div class="box-footer">
		<button type="submit" class="btn btn-primary"><i class="fa fa-check"></i>&nbsp;&nbsp;Apply</button>
	</div>
}
<div class="box">
	<table class="table table-striped table-bordered table-hover">
		<colgroup>
			<col>
			<col class="col-md-2">
			<col class="col-md-4">
			<col class="col-md-6">
		</colgroup>
		<thead>
			<tr>
				<th><a href="@Url.Action("Edit")" class="btn btn-xs btn-primary"><i class="fa fa-plus"></i></a></th>
				<th>Id</th>
				<th>Number</th>
				<th>Name</th>
			</tr>
		</thead>
		<tbody data-sortable="@Url.Action("Move")">
			@foreach (var item in Model.Items)
			{
				<tr data-id="@item.Id">
					<td><a href="@Url.Action("Edit", new { item.Id })" class="btn btn-xs btn-primary"><i class="fa fa-pencil"></i></a></td>
					<td>@Html.DisplayFor(x => item.Id)</td>
					<td>@Html.DisplayFor(x => item.Number)</td>
					<td>@Html.DisplayFor(x => item.Name)</td>
				</tr>
			}
		</tbody>
		<tfoot>
			<tr>
				<td colspan="4">
					@Html.Partial("Pager", Model.Items)
				</td>
			</tr>
		</tfoot>
	</table>
</div>

@section scripts {
	@Scripts.Render("~/bundles/js-sortable")
}